# En-têtes de sécurité HTTP — lus automatiquement par Netlify au déploiement.
#
# L'application est statique, sans compte ni authentification : ces en-têtes ne
# corrigent aucune faille connue, ils réduisent la surface d'attaque si une
# dépendance ou une page venait à être détournée.

/*
  # Interdit à un site tiers d'encapsuler l'application dans une iframe
  # (protection contre le détournement de clic).
  X-Frame-Options: DENY

  # Le navigateur ne doit pas « deviner » le type d'un fichier servi.
  X-Content-Type-Options: nosniff

  # Ne transmet l'URL complète qu'aux pages du même site.
  Referrer-Policy: strict-origin-when-cross-origin

  # Aucune fonctionnalité sensible n'est utilisée, sauf le micro (dictée vocale).
  Permissions-Policy: camera=(), geolocation=(), payment=(), usb=(), microphone=(self)

  # Content Security Policy : liste blanche stricte des origines autorisées.
  #   'self'           -> scripts, styles et polices de l'application (jsPDF et
  #                       les WOFF2 sont hébergés localement : aucun CDN)
  #   docs.google.com  -> envoi des statistiques anonymes vers le formulaire
  # 'unsafe-inline' est toléré pour les STYLES (le code pose des attributs
  # style="" en JavaScript) mais JAMAIS pour les scripts.
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; form-action https://docs.google.com; connect-src 'self' https://docs.google.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'




